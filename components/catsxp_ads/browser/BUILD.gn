    "test/fake_ads_service_delegate.h",
    "test/fake_ads_tooltips_delegate.cc",
    "test/fake_ads_tooltips_delegate.h",
    "test/fake_bat_ads.cc",
    "test/fake_bat_ads.h",
    "test/fake_bat_ads_client_notifier.cc",
    "test/fake_bat_ads_client_notifier.h",
    "test/fake_bat_ads_service.cc",
    "test/fake_bat_ads_service.h",
    "test/fake_bat_ads_service_factory.cc",
    "test/fake_bat_ads_service_factory.h",
    "test/fake_device_id.cc",
    "test/fake_device_id.h",
    "test/fake_virtual_pref_provider_delegate.cc",
    "test/fake_virtual_pref_provider_delegate.h",
  ]

  deps = [
    ":browser",
    "//base",
    "//catsxp/components/catsxp_ads/core/mojom",
    "//catsxp/components/services/bat_ads/public/interfaces:mojom",
    "//components/prefs",
