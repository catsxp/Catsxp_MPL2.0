    "//catsxp/components/catsxp_policy:policy_initialization_waiter",
    "//catsxp/components/catsxp_rewards/core",
    "//catsxp/components/catsxp_rewards/core:features",
    "//catsxp/components/catsxp_rewards/core/buildflags",
