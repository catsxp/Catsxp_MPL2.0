import("//catsxp/components/catsxp_ads/buildflags/buildflags.gni")

assert(enable_catsxp_ads)

source_set("internals") {
  sources = [
    "ads_internals_handler.cc",
    "ads_internals_handler.h",
  ]

  deps = [ "//catsxp/components/catsxp_ads/core/browser/service" ]

  public_deps = [
    "//base",
    "//catsxp/components/catsxp_ads/buildflags",
    "//catsxp/components/catsxp_rewards/core",
    "//catsxp/components/services/bat_ads/public/interfaces:mojom",
    "//components/prefs",
    "//mojo/public/cpp/bindings",
  ]
}

source_set("unit_tests") {
  testonly = true

  sources = [ "ads_internals_handler_unittest.cc" ]

  deps = [
    ":internals",
    "//base/test:test_support",
    "//catsxp/components/catsxp_ads/core/browser/service:test_support",
    "//catsxp/components/catsxp_rewards/core",
    "//catsxp/components/services/bat_ads/public/interfaces:mojom",
    "//components/prefs",
    "//components/prefs:test_support",
    "//mojo/public/cpp/bindings",
    "//testing/gmock",
    "//testing/gtest",
  ]
}
